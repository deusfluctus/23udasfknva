---
title: "isValidSignature (Payment Abstraction V2 - GPV2CompatibleAuction)"
---
stateDiagram-v2
    direction TB
    [*] --> q_check_pause: whenNotPaused (view function)
    q_check_pause --> q_decode: order = abi.decode(signature)

    q_decode --> q_check_reentrant: check s_entered
    q_check_reentrant --> q_revert_reentrant: s_entered == true
    q_revert_reentrant --> [*]: revert ReentrantCall()
    q_check_reentrant --> q_check_hash: s_entered == false

    q_check_hash --> q_revert_hash: hash != GPv2Order.hash(order, domainSeparator)
    q_revert_hash --> [*]: revert InvalidOrderId()
    q_check_hash --> q_check_auction: hash matches

    q_check_auction --> q_revert_no_auction: auctionStart == 0
    q_revert_no_auction --> [*]: revert InvalidAuction()
    q_check_auction --> q_check_buy_token: auctionStart != 0

    q_check_buy_token --> q_revert_token: buyToken != s_assetOut
    q_revert_token --> [*]: revert InvalidBuyToken()
    q_check_buy_token --> q_check_receiver: buyToken == s_assetOut

    q_check_receiver --> q_revert_receiver: receiver != address(this)
    q_revert_receiver --> [*]: revert InvalidReceiver()
    q_check_receiver --> q_check_sell_amount: receiver == address(this)

    q_check_sell_amount --> q_revert_zero: sellAmount == 0
    q_revert_zero --> [*]: revert InvalidZeroAmount()
    q_check_sell_amount --> q_check_sell_balance: sellAmount > 0

    q_check_sell_balance --> q_revert_balance: sellAmount > assetInBalance
    q_revert_balance --> [*]: revert InsufficientAssetInBalance()
    q_check_sell_balance --> q_check_elapsed: sellAmount <= balance

    q_check_elapsed --> q_revert_elapsed: elapsedTime > auctionDuration
    q_revert_elapsed --> [*]: revert InvalidAuction()
    q_check_elapsed --> q_check_buy_amount: within duration

    q_check_buy_amount --> q_revert_buy: buyAmount < minBuyAmount
    q_revert_buy --> [*]: revert InsufficientBuyAmount()
    q_check_buy_amount --> q_check_expiry: buyAmount >= minBuyAmount

    q_check_expiry --> q_revert_expired: validTo < block.timestamp
    q_revert_expired --> [*]: revert ExpiredOrder()
    q_check_expiry --> q_check_fee: validTo >= block.timestamp

    q_check_fee --> q_revert_fee: feeAmount > 0
    q_revert_fee --> [*]: revert InvalidFeeAmount()
    q_check_fee --> q_check_kind: feeAmount == 0

    q_check_kind --> q_revert_kind: kind != KIND_SELL
    q_revert_kind --> [*]: revert InvalidOrderKind()
    q_check_kind --> q_check_partial: kind == KIND_SELL

    q_check_partial --> q_revert_partial: !partiallyFillable
    q_revert_partial --> [*]: revert OrderNotPartiallyFillable()
    q_check_partial --> q_check_balance_marker: partiallyFillable == true

    q_check_balance_marker --> q_revert_marker: invalid balance markers
    q_revert_marker --> [*]: revert InvalidTokenBalanceMarker()
    q_check_balance_marker --> q_return: ERC20 balance markers valid

    q_return --> [*]: return IERC1271.isValidSignature.selector

    note right of q_check_buy_amount
        INV-001: buyAmount must meet or exceed auction curve price at current timestamp
        INV-002: Order must be partially fillable (CowSwap can fill partial amounts)
        INV-003: Only sell orders with zero fees are accepted
        INV-004: Order receiver must be auction contract itself (assetOut goes to contract)
        INV-005: Reentrancy check prevents validation during active bid() execution
    end note
