---
title: "bid (BaseAuction)"
---
stateDiagram-v2
    direction TB
    [*] --> q_reentrancy: require whenNotPaused
    q_reentrancy --> q_revert_reentrant: s_entered == true
    q_revert_reentrant --> [*]: revert ReentrantCall
    q_reentrancy --> q_lock: s_entered == false
    q_lock --> q_check_auction: s_entered = true
    q_check_auction --> q_revert_invalid: auctionStart == 0 OR elapsedTime > auctionDuration
    q_revert_invalid --> [*]: revert InvalidAuction
    q_check_auction --> q_get_price: valid auction
    q_get_price --> q_check_min_bid: assetPrice = _getAssetPrice(asset, true)
    q_check_min_bid --> q_revert_too_low: bidUsdValue < minBidUsdValue
    q_revert_too_low --> [*]: revert BidValueTooLow
    q_check_min_bid --> q_check_balance: above minimum
    q_check_balance --> q_revert_too_high: amount > availableBalance
    q_revert_too_high --> [*]: revert BidAmountTooHigh
    q_check_balance --> q_compute_out: amount <= availableBalance
    q_compute_out --> q_transfer_asset: assetOutAmount = _getAssetOutAmount(...)
    q_transfer_asset --> q_check_callback: transfer asset to msg.sender
    q_check_callback --> q_do_callback: data.length != 0
    q_check_callback --> q_pull_payment: data.length == 0
    q_do_callback --> q_pull_payment: IAuctionCallback(msg.sender).auctionCallback(...)
    q_pull_payment --> q_emit: safeTransferFrom(msg.sender, this, assetOutAmount)
    q_emit --> q_unlock: emit AuctionBidSettled
    q_unlock --> [*]: s_entered = false

    note right of q_lock
        INV-001: Reentrancy guard via s_entered flag prevents recursive calls
        INV-002: Asset transferred to bidder BEFORE callback execution (optimistic transfer)
    end note

    note right of q_do_callback
        INV-003: Callback allows bidder to source assetOut before payment pull
        INV-004: Payment of assetOutAmount is always pulled after callback
        INV-005: Bid amount must not exceed available auction balance
    end note
